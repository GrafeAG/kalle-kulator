# ═══════════════════════════════════════════════════════
# KALLE-SERVER Konfiguration
# Diese Datei NICHT in Git committen (steht in .gitignore)
# ═══════════════════════════════════════════════════════

# Server
PORT=8765
NODE_ENV=production

# PostgreSQL Datenbank
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kalle
DB_USER=kalle_user
DB_PASSWORD=SICHERES_PASSWORT_HIER_EINTRAGEN

# Netzlaufwerk-Pfade (Windows-Format mit Forward-Slashes)
NETZLAUFWERK=Z:/01-Kundenprojekte
OFFERTEN_PFAD=Z:/10-Marketing-Verkauf/15-Kalkulationsgrundlagen/Offerten
PREISLISTE_PFAD=Z:/10-Marketing-Verkauf/15-Kalkulationsgrundlagen/kalle-preise.json

# CORS — welche Browser-URLs dürfen auf die API zugreifen
# Bei Netzlaufwerk: file:// erlauben
CORS_ORIGINS=*
